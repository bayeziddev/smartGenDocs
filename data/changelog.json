FILE="data/changelog.json"

if [ ! -f "$FILE" ]; then
  echo "data/changelog.json not found!"
  exit 1
fi

jq \
  --arg title "${{ steps.commit_info.outputs.TITLE }}" \
  --arg description "${{ steps.commit_info.outputs.DESC }}" \
  --arg author "${GITHUB_ACTOR}" \
  --arg repository "${GITHUB_REPOSITORY}" \
  --arg repository_url "https://github.com/${GITHUB_REPOSITORY}" \
  --arg branch "${GITHUB_REF_NAME}" \
  --arg sha "${GITHUB_SHA}" \
  --arg short "${GITHUB_SHA::7}" \
  --arg commit_url "https://github.com/${GITHUB_REPOSITORY}/commit/${GITHUB_SHA}" \
  --arg website "https://bayeziddev.github.io/smartGenDocs/" \
  --arg date "$(date -u +"%Y-%m-%dT%H:%M:%SZ")" \
  --argjson changed_files '[]' \
  --arg files_changed "0" \
  --arg insertions "0" \
  --arg deletions "0" \
'
.entries |= [{
    version: "development",
    title: $title,
    description:
      (if $description == ""
       then "Platform improvements and optimizations."
       else $description
       end),
    author: $author,
    repository: $repository,
    repository_url: $repository_url,
    branch: $branch,
    commit: $sha,
    short_commit: $short,
    commit_url: $commit_url,
    website: $website,
    date: $date,
    files_changed: ($files_changed|tonumber),
    insertions: ($insertions|tonumber),
    deletions: ($deletions|tonumber),
    changed_files: $changed_files
}] + .

| .statistics.total_entries = (.entries | length)
| .statistics.total_commits = (.entries | length)
| .statistics.last_updated = $date
| .generated_at = $date
' "$FILE" > temp.json

mv temp.json "$FILE"